<div id="dor-ciatica" class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:border-primary/50 transition-colors">
<div class="flex items-center gap-4 mb-4">
<div class="w-14 h-14 bg-primary/10 text-primary rounded-full flex items-center justify-center text-3xl shadow-inner">⚡</div>
