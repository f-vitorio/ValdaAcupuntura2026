---
import Layout from '../layouts/Layout.astro';
import { Image, getImage } from 'astro:assets';
import heroImgSource from '../assets/hero-premium.webp';
import valdaImg from '../assets/valda-real.webp';
import logoImg from '../assets/logo-valda.webp';

// Pre-optimize hero image
const heroImgOptimized = await getImage({
src: heroImgSource, 
format: 'avif',
width: 800,
});
---

<Layout 
title="Clínica de Acupuntura em SP: Tratamento para Ansiedade e Dor"
description="Procurando clínica de acupuntura perto de mim? Tratamento especializado para ansiedade, insônia, enxaqueca e dor nas costas. Agende na Vila Guarani, SP."
    heroPreloadUrl={heroImgOptimized.src}>

<!-- Schema.org Avançado para Google Ads (MedicalClinic + Tratamentos) -->
<script type="application/ld+json" set:html={JSON.stringify({
"@context": "https://schema.org",
"@graph": [
{
"@type": "MedicalClinic",
"@id": "https://valdaacupuntura.com.br/#clinic",
"name": "Valda Acupuntura",
"description": "Clínica de acupuntura especializada no tratamento de dores crônicas, ansiedade, enxaqueca e insônia na Vila Guarani, Zona Sul de São Paulo.",
"image": "https://valdaacupuntura.com.br/valda-real.webp",
"telephone": "+5511983134656",
"address": {
"@type": "PostalAddress",
"streetAddress": "Av. do Café, 999",
"addressLocality": "São Paulo",
"addressRegion": "SP",
"addressCountry": "BR"
},
"medicalSpecialty": "Acupuncture",
"availableService": [
{
"@type": "MedicalTherapy",
"name": "Acupuntura para Ansiedade",
"description": "Tratamento natural para controle de estresse e ansiedade."
},
{
"@type": "MedicalTherapy",
"name": "Acupuntura para Enxaqueca",
"description": "Alívio de dores de cabeça tensionais e enxaquecas."
},
{
"@type": "MedicalTherapy",
"name": "Acupuntura para Dor nas Costas",
"description": "Tratamento para dores na coluna, lombar e nervo ciático."
},
{
"@type": "MedicalTherapy",
"name": "Acupuntura para Insônia",
"description": "Reequilíbrio do sistema nervoso para melhora da qualidade do sono."
}
]
},
{
"@type": "FAQPage",
"mainEntity": [
{
"@type": "Question",
"name": "Acupuntura serve para ansiedade?",
"acceptedAnswer": {
"@type": "Answer",
"text": "Sim. A acupuntura estimula a produção de serotonina e endorfina, ajudando a regular o sistema nervoso, diminuindo os níveis de cortisol (hormônio do estresse) e proporcionando profundo relaxamento."
}
},
{
"@type": "Question",
"name": "Acupuntura ajuda na dor nas costas e coluna?",
"acceptedAnswer": {
"@type": "Answer",
"text": "Completamente. Utilizamos técnicas de eletroacupuntura que promovem descompressão muscular, aliviam a inflamação e melhoram o fluxo sanguíneo na região, sendo extremamente eficaz para lombalgias e nervo ciático."
}
},
{
"@type": "Question",
"name": "Onde fica a clínica de acupuntura?",
"acceptedAnswer": {
"@type": "Answer",
"text": "Nossa clínica está localizada na Zona Sul de São Paulo, na Av. do Café, 999 - Vila Guarani, bem próximo à estação de Metrô Conceição."
}
}
]
}
]
})} />

<!-- Header -->
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm border-b border-gray-100 py-2">
<div class="container mx-auto px-4 flex justify-between items-center max-w-6xl">
<a href="/" class="flex items-center gap-3 no-underline group">
<Image src={logoImg} alt="Logo Valda Acupuntura" width={48} height={48} class="rounded-full shadow-sm group-hover:scale-105 transition-transform w-10 h-10 md:w-12 md:h-12" loading="eager" />
<span class="font-serif font-bold text-primary text-xl tracking-tight">Valda Acupuntura</span>
</a>
<div class="flex items-center gap-6">
<nav class="hidden md:flex items-center gap-6">
<a href="#precos" class="font-medium text-gray-700 hover:text-primary transition-colors text-lg">Preços</a>
</nav>
<a href="tel:+5511983134656" class="hidden md:flex items-center gap-2 font-bold text-primary hover:text-accent transition-colors text-lg" aria-label="Ligar para (11) 98313-4656">
<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 0 0-1.01.24l-1.57 1.97c-2.83-1.49-5.15-3.8-6.64-6.64l1.97-1.57c.23-.23.33-.55.24-1.01a11.36 11.36 0 0 0-.56-3.53.974.974 0 0 0-1-.75H3.03c-.55 0-1 .45-1 1C2.03 15.35 12.65 25.96 24 24.96c.55 0 1-.45 1-1v-4.89c0-.55-.45-1-1-1zM11 7V5c0-1.1.9-2 2-2h2c1.1 0 2 .9 2 2v2h-6z" /></svg>
(11) 98313-4656
</a>
<a href="https://wa.me/5511983134656?text=Olá,%20vim%20pelo%20Google.%20Gostaria%20de%20agendar%20uma%20avaliação." class="bg-secondary text-white px-5 py-2.5 rounded-full font-bold text-sm hover:bg-green-600 transition-transform hover:-translate-y-0.5 shadow-md flex items-center gap-2 animate-pulse-slow">
Agendar Avaliação
</a>
</div>
</div>
</header>

<main>
<!-- Hero Section -->
<section class="relative py-20 md:py-32 text-center overflow-hidden">
<!-- Background Image -->
<img 
src={heroImgOptimized.src}
alt="Valda Acupuntura Clínica" 
class="absolute inset-0 w-full h-full object-cover object-center z-0"
fetchpriority="high"
loading="eager"
decoding="async"
width={heroImgOptimized.attributes.width}
height={heroImgOptimized.attributes.height}
/>
<!-- Gradient Overlay -->
<div class="absolute inset-0 bg-gradient-to-b from-[#e8f5e9]/95 to-white/90 z-0"></div>

<div class="container mx-auto px-4 max-w-4xl relative z-10">
<span class="inline-flex items-center gap-2 bg-[#e6fffa] text-[#047857] px-5 py-2.5 rounded-full font-semibold text-sm mb-6 border border-[#b7eb8f] shadow-sm animate-fade-in mx-auto">
<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
